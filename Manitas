<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>HAND.FORGE — Constructor 3D con Manos</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@400;700;800&display=swap');

  :root {
    --bg: #0a0a0f;
    --panel: #10101a;
    --border: #1e1e30;
    --accent: #00ffcc;
    --accent2: #ff3366;
    --accent3: #ffcc00;
    --text: #e0e0f0;
    --dim: #444466;
    --cube: #3355ff;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Space Mono', monospace;
    height: 100vh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 24px;
    border-bottom: 1px solid var(--border);
    background: var(--panel);
    z-index: 100;
  }

  .logo {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 20px;
    letter-spacing: 4px;
    color: var(--accent);
    text-transform: uppercase;
  }
  .logo span { color: var(--accent2); }

  .status-bar {
    display: flex;
    gap: 16px;
    align-items: center;
    font-size: 11px;
    color: var(--dim);
  }

  .status-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--accent2);
    transition: background 0.3s;
  }
  .status-dot.active { background: var(--accent); box-shadow: 0 0 8px var(--accent); }

  #status-label { transition: color 0.3s; }

  .main {
    display: flex;
    flex: 1;
    overflow: hidden;
  }

  /* SIDEBAR */
  .sidebar {
    width: 220px;
    background: var(--panel);
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    padding: 16px;
    gap: 20px;
    z-index: 10;
    overflow-y: auto;
  }

  .sidebar-section h3 {
    font-family: 'Syne', sans-serif;
    font-size: 10px;
    letter-spacing: 3px;
    color: var(--dim);
    text-transform: uppercase;
    margin-bottom: 12px;
    border-bottom: 1px solid var(--border);
    padding-bottom: 6px;
  }

  .gesture-card {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 10px;
    border-radius: 6px;
    border: 1px solid var(--border);
    margin-bottom: 8px;
    transition: all 0.2s;
    background: #0d0d18;
  }
  .gesture-card.active {
    border-color: var(--accent);
    background: rgba(0,255,204,0.05);
    box-shadow: 0 0 12px rgba(0,255,204,0.1);
  }
  .gesture-card.active2 {
    border-color: var(--accent2);
    background: rgba(255,51,102,0.05);
    box-shadow: 0 0 12px rgba(255,51,102,0.1);
  }
  .gesture-card.active3 {
    border-color: var(--accent3);
    background: rgba(255,204,0,0.05);
    box-shadow: 0 0 12px rgba(255,204,0,0.1);
  }

  .gesture-icon {
    font-size: 22px;
    line-height: 1;
    min-width: 28px;
    text-align: center;
  }

  .gesture-info { flex: 1; }
  .gesture-name {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 11px;
    color: var(--text);
    margin-bottom: 3px;
  }
  .gesture-desc { font-size: 9px; color: var(--dim); line-height: 1.4; }

  .stat-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 6px 0;
    border-bottom: 1px solid var(--border);
    font-size: 11px;
  }
  .stat-label { color: var(--dim); }
  .stat-val { color: var(--accent); font-weight: 700; }

  .btn-clear {
    width: 100%;
    padding: 10px;
    background: rgba(255,51,102,0.1);
    border: 1px solid var(--accent2);
    color: var(--accent2);
    border-radius: 4px;
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    letter-spacing: 2px;
    cursor: pointer;
    text-transform: uppercase;
    transition: all 0.2s;
  }
  .btn-clear:hover {
    background: rgba(255,51,102,0.2);
    box-shadow: 0 0 12px rgba(255,51,102,0.3);
  }

  /* CENTER: Camera + Canvas */
  .center {
    flex: 1;
    position: relative;
    display: flex;
    align-items: stretch;
  }

  #videoEl {
    position: absolute;
    width: 100%; height: 100%;
    object-fit: cover;
    opacity: 0.18;
    transform: scaleX(-1);
    pointer-events: none;
  }

  #handCanvas {
    position: absolute;
    width: 100%; height: 100%;
    transform: scaleX(-1);
    pointer-events: none;
    z-index: 2;
  }

  #threeCanvas {
    position: absolute;
    width: 100%; height: 100%;
    z-index: 1;
  }

  /* Gesture feedback HUD */
  .gesture-hud {
    position: absolute;
    bottom: 16px;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(10,10,15,0.85);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 10px 24px;
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 3px;
    color: var(--accent);
    text-transform: uppercase;
    z-index: 10;
    backdrop-filter: blur(8px);
    transition: all 0.3s;
    white-space: nowrap;
    pointer-events: none;
    opacity: 0;
  }
  .gesture-hud.show { opacity: 1; }

  /* Loading overlay */
  #loadingOverlay {
    position: absolute;
    inset: 0;
    background: var(--bg);
    z-index: 100;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 20px;
    transition: opacity 0.5s;
  }
  #loadingOverlay.hidden { opacity: 0; pointer-events: none; }

  .loading-title {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 28px;
    letter-spacing: 6px;
    color: var(--accent);
  }
  .loading-sub { font-size: 11px; color: var(--dim); letter-spacing: 2px; }

  .loader-bar {
    width: 200px; height: 2px;
    background: var(--border);
    border-radius: 2px;
    overflow: hidden;
  }
  .loader-fill {
    height: 100%;
    background: var(--accent);
    border-radius: 2px;
    animation: load 2s ease-in-out infinite;
  }
  @keyframes load {
    0% { width: 0; }
    50% { width: 80%; }
    100% { width: 100%; }
  }

  .scan-lines {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0,255,204,0.015) 2px,
      rgba(0,255,204,0.015) 4px
    );
    pointer-events: none;
    z-index: 5;
  }

  /* Color picker */
  .color-options {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .color-opt {
    width: 28px; height: 28px;
    border-radius: 4px;
    cursor: pointer;
    border: 2px solid transparent;
    transition: all 0.2s;
  }
  .color-opt.selected { border-color: white; transform: scale(1.15); }
</style>
</head>
<body>

<header>
  <div class="logo">HAND<span>.</span>FORGE</div>
  <div class="status-bar">
    <div class="status-dot" id="statusDot"></div>
    <span id="status-label">INICIANDO...</span>
    <span style="color:var(--border)">|</span>
    <span id="fps-label" style="color:var(--dim)">-- FPS</span>
  </div>
</header>

<div class="main">
  <!-- SIDEBAR -->
  <div class="sidebar">
    <div class="sidebar-section">
      <h3>Gestos</h3>

      <div class="gesture-card" id="gc-pinch">
        <div class="gesture-icon">🤏</div>
        <div class="gesture-info">
          <div class="gesture-name">PINCH</div>
          <div class="gesture-desc">Índice + Pulgar juntos → Crear cubo</div>
        </div>
      </div>

      <div class="gesture-card" id="gc-fist">
        <div class="gesture-icon">✊</div>
        <div class="gesture-info">
          <div class="gesture-name">PUÑO</div>
          <div class="gesture-desc">Todos los dedos cerrados → Mover cubo</div>
        </div>
      </div>

      <div class="gesture-card" id="gc-open">
        <div class="gesture-icon">🖐</div>
        <div class="gesture-info">
          <div class="gesture-name">PALMA</div>
          <div class="gesture-desc">Mano abierta → Rotar escena</div>
        </div>
      </div>

      <div class="gesture-card" id="gc-peace">
        <div class="gesture-icon">✌️</div>
        <div class="gesture-info">
          <div class="gesture-name">V / PEACE</div>
          <div class="gesture-desc">Índice + Medio → Escalar cubo</div>
        </div>
      </div>

      <div class="gesture-card" id="gc-point">
        <div class="gesture-icon">☝️</div>
        <div class="gesture-info">
          <div class="gesture-name">SEÑALAR</div>
          <div class="gesture-desc">Solo índice → Seleccionar cubo</div>
        </div>
      </div>
    </div>

    <div class="sidebar-section">
      <h3>Color del Cubo</h3>
      <div class="color-options" id="colorOptions">
        <div class="color-opt selected" data-color="#3355ff" style="background:#3355ff"></div>
        <div class="color-opt" data-color="#00ffcc" style="background:#00ffcc"></div>
        <div class="color-opt" data-color="#ff3366" style="background:#ff3366"></div>
        <div class="color-opt" data-color="#ffcc00" style="background:#ffcc00"></div>
        <div class="color-opt" data-color="#ff6600" style="background:#ff6600"></div>
        <div class="color-opt" data-color="#aa00ff" style="background:#aa00ff"></div>
        <div class="color-opt" data-color="#ffffff" style="background:#ffffff"></div>
      </div>
    </div>

    <div class="sidebar-section">
      <h3>Estadísticas</h3>
      <div class="stat-row">
        <span class="stat-label">Cubos</span>
        <span class="stat-val" id="cube-count">0</span>
      </div>
      <div class="stat-row">
        <span class="stat-label">Gesto</span>
        <span class="stat-val" id="current-gesture">—</span>
      </div>
      <div class="stat-row">
        <span class="stat-label">Manos</span>
        <span class="stat-val" id="hand-count">0</span>
      </div>
    </div>

    <div class="sidebar-section">
      <h3>Acciones</h3>
      <button class="btn-clear" id="clearBtn">⬜ Limpiar Todo</button>
    </div>
  </div>

  <!-- CENTER -->
  <div class="center">
    <video id="videoEl" autoplay playsinline muted></video>
    <canvas id="threeCanvas"></canvas>
    <canvas id="handCanvas"></canvas>
    <div class="scan-lines"></div>
    <div class="gesture-hud" id="gestureHud">—</div>

    <div id="loadingOverlay">
      <div class="loading-title">HAND.FORGE</div>
      <div class="loading-sub">CARGANDO MODELOS DE DETECCIÓN...</div>
      <div class="loader-bar"><div class="loader-fill"></div></div>
    </div>
  </div>
</div>

<!-- Scripts -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@mediapipe/camera_utils/camera_utils.js" crossorigin="anonymous"></script>
<script src="https://cdn.jsdelivr.net/npm/@mediapipe/control_utils/control_utils.js" crossorigin="anonymous"></script>
<script src="https://cdn.jsdelivr.net/npm/@mediapipe/hands/hands.js" crossorigin="anonymous"></script>

<script>
// ─────────────────────────────────────────────
// THREE.JS SCENE SETUP
// ─────────────────────────────────────────────
const threeCanvas = document.getElementById('threeCanvas');
const renderer = new THREE.WebGLRenderer({ canvas: threeCanvas, antialias: true, alpha: true });
renderer.setPixelRatio(window.devicePixelRatio);
renderer.shadowMap.enabled = true;
renderer.shadowMap.type = THREE.PCFSoftShadowMap;

const scene = new THREE.Scene();
scene.fog = new THREE.FogExp2(0x0a0a0f, 0.04);

const camera3d = new THREE.PerspectiveCamera(60, 1, 0.1, 1000);
camera3d.position.set(0, 5, 14);
camera3d.lookAt(0, 0, 0);

// Lighting
const ambientLight = new THREE.AmbientLight(0x222244, 1.2);
scene.add(ambientLight);

const dirLight = new THREE.DirectionalLight(0x00ffcc, 1.5);
dirLight.position.set(5, 10, 5);
dirLight.castShadow = true;
scene.add(dirLight);

const dirLight2 = new THREE.DirectionalLight(0xff3366, 0.8);
dirLight2.position.set(-5, 3, -5);
scene.add(dirLight2);

const pointLight = new THREE.PointLight(0xffffff, 0.5, 30);
pointLight.position.set(0, 8, 0);
scene.add(pointLight);

// Grid
const gridHelper = new THREE.GridHelper(30, 30, 0x1a1a2e, 0x0d0d1a);
scene.add(gridHelper);

// Ground plane (invisible, for shadows)
const groundGeo = new THREE.PlaneGeometry(50, 50);
const groundMat = new THREE.MeshStandardMaterial({ color: 0x0a0a0f, roughness: 1 });
const ground = new THREE.Mesh(groundGeo, groundMat);
ground.rotation.x = -Math.PI / 2;
ground.position.y = -0.5;
ground.receiveShadow = true;
scene.add(ground);

// ─────────────────────────────────────────────
// CURSOR 3D (ghost cube preview)
// ─────────────────────────────────────────────
let selectedColor = 0x3355ff;
const ghostGeo = new THREE.BoxGeometry(1, 1, 1);
const ghostMat = new THREE.MeshStandardMaterial({
  color: selectedColor, transparent: true, opacity: 0.3,
  wireframe: false, emissive: selectedColor, emissiveIntensity: 0.3
});
const ghostCube = new THREE.Mesh(ghostGeo, ghostMat);
ghostCube.visible = false;
scene.add(ghostCube);

// ─────────────────────────────────────────────
// STATE
// ─────────────────────────────────────────────
let cubes = [];
let selectedCube = null;
let sceneRotY = 0;
let sceneRotX = 0;
let prevHandPos = null;
let prevPinch = false;
let prevFist = false;
let prevPinchDist = null;
let gestureHudTimeout = null;
let fpsCounter = 0, fpsLast = Date.now();

const cubeCountEl = document.getElementById('cube-count');
const gestureEl = document.getElementById('current-gesture');
const handCountEl = document.getElementById('hand-count');
const gestureHudEl = document.getElementById('gestureHud');
const statusDot = document.getElementById('statusDot');
const statusLabel = document.getElementById('status-label');

// ─────────────────────────────────────────────
// COLOR OPTIONS
// ─────────────────────────────────────────────
document.getElementById('colorOptions').addEventListener('click', e => {
  const opt = e.target.closest('.color-opt');
  if (!opt) return;
  document.querySelectorAll('.color-opt').forEach(o => o.classList.remove('selected'));
  opt.classList.add('selected');
  selectedColor = parseInt(opt.dataset.color.replace('#', '0x'));
  ghostMat.color.setHex(selectedColor);
  ghostMat.emissive.setHex(selectedColor);
});

// ─────────────────────────────────────────────
// CLEAR
// ─────────────────────────────────────────────
document.getElementById('clearBtn').addEventListener('click', () => {
  cubes.forEach(c => scene.remove(c.mesh));
  cubes = [];
  selectedCube = null;
  cubeCountEl.textContent = '0';
});

// ─────────────────────────────────────────────
// GESTURE DETECTION HELPERS
// ─────────────────────────────────────────────
function dist2d(a, b) {
  return Math.hypot(a.x - b.x, a.y - b.y);
}
function fingerExtended(lm, tip, pip) {
  return lm[tip].y < lm[pip].y;
}

function detectGesture(lm) {
  const thumbTip  = lm[4],  thumbIp  = lm[3];
  const indexTip  = lm[8],  indexPip = lm[6];
  const middleTip = lm[12], middlePip= lm[10];
  const ringTip   = lm[16], ringPip  = lm[14];
  const pinkyTip  = lm[20], pinkyPip = lm[18];

  const pinchDist = dist2d(thumbTip, indexTip);
  const isPinch = pinchDist < 0.07;

  const indexExt  = indexTip.y  < indexPip.y;
  const middleExt = middleTip.y < middlePip.y;
  const ringExt   = ringTip.y   < ringPip.y;
  const pinkyExt  = pinkyTip.y  < pinkyPip.y;

  const extCount = [indexExt, middleExt, ringExt, pinkyExt].filter(Boolean).length;
  const isFist = extCount === 0;
  const isOpen = extCount >= 3;
  const isPoint = indexExt && !middleExt && !ringExt && !pinkyExt;
  const isPeace = indexExt && middleExt && !ringExt && !pinkyExt;

  return { isPinch, isFist, isOpen, isPoint, isPeace, pinchDist, extCount };
}

// ─────────────────────────────────────────────
// HAND → 3D WORLD COORDS
// ─────────────────────────────────────────────
function handTo3D(lm, index) {
  const lk = lm[index];
  // Map [0,1] x,y to world space [-7,7] with some depth from z
  const x = (0.5 - lk.x) * 14;
  const y = (0.5 - lk.y) * 8 + 2;
  return new THREE.Vector3(x, y, 0);
}

// Snap to grid
function snapGrid(v, step = 1) {
  return new THREE.Vector3(
    Math.round(v.x / step) * step,
    Math.max(0, Math.round(v.y / step) * step),
    Math.round(v.z / step) * step
  );
}

// ─────────────────────────────────────────────
// CUBE FACTORY
// ─────────────────────────────────────────────
function createCube(pos, color) {
  const geo = new THREE.BoxGeometry(1, 1, 1);
  const mat = new THREE.MeshStandardMaterial({
    color,
    roughness: 0.4,
    metalness: 0.6,
    emissive: color,
    emissiveIntensity: 0.08
  });
  const mesh = new THREE.Mesh(geo, mat);

  // Wireframe overlay
  const wireMat = new THREE.MeshBasicMaterial({ color: 0xffffff, wireframe: true, opacity: 0.08, transparent: true });
  const wire = new THREE.Mesh(geo, wireMat);
  mesh.add(wire);

  mesh.position.copy(pos);
  mesh.castShadow = true;
  mesh.receiveShadow = true;
  scene.add(mesh);

  // Spawn animation
  mesh.scale.set(0.01, 0.01, 0.01);
  const obj = { mesh, color, spawning: true, spawnT: 0 };
  cubes.push(obj);
  cubeCountEl.textContent = cubes.length;
  return obj;
}

// ─────────────────────────────────────────────
// HIGHLIGHT
// ─────────────────────────────────────────────
function highlightCube(cubeObj) {
  if (selectedCube) {
    selectedCube.mesh.material.emissiveIntensity = 0.08;
  }
  selectedCube = cubeObj;
  if (cubeObj) cubeObj.mesh.material.emissiveIntensity = 0.5;
}

// ─────────────────────────────────────────────
// SHOW GESTURE HUD
// ─────────────────────────────────────────────
function showHud(text) {
  gestureHudEl.textContent = text;
  gestureHudEl.classList.add('show');
  clearTimeout(gestureHudTimeout);
  gestureHudTimeout = setTimeout(() => gestureHudEl.classList.remove('show'), 1500);
}

function setGestureCard(id) {
  document.querySelectorAll('.gesture-card').forEach(c => {
    c.classList.remove('active', 'active2', 'active3');
  });
  if (id) {
    const el = document.getElementById(id);
    if (el) {
      const cls = id === 'gc-pinch' ? 'active' : id === 'gc-fist' ? 'active2' : 'active3';
      el.classList.add(cls);
    }
  }
}

// ─────────────────────────────────────────────
// PROCESS HAND LANDMARKS
// ─────────────────────────────────────────────
let handOverlay = document.getElementById('handCanvas');
let hCtx = handOverlay.getContext('2d');

function processResults(results) {
  // Resize overlays
  const { videoWidth: vw, videoHeight: vh } = document.getElementById('videoEl');
  const rect = document.getElementById('threeCanvas').getBoundingClientRect();
  handOverlay.width = rect.width;
  handOverlay.height = rect.height;
  hCtx.clearRect(0, 0, handOverlay.width, handOverlay.height);

  handCountEl.textContent = results.multiHandLandmarks?.length || 0;

  if (!results.multiHandLandmarks || results.multiHandLandmarks.length === 0) {
    ghostCube.visible = false;
    prevHandPos = null;
    prevPinch = false;
    prevFist = false;
    gestureEl.textContent = '—';
    setGestureCard(null);
    return;
  }

  const lm = results.multiHandLandmarks[0];
  const gesture = detectGesture(lm);

  // Draw skeleton
  drawHand(lm, gesture);

  // ── WRIST position for scene control
  const wrist = lm[0];
  const wx = wrist.x, wy = wrist.y;

  // ── PINCH → Create cube
  if (gesture.isPinch && !prevPinch) {
    const pos3d = handTo3D(lm, 8);
    const snapped = snapGrid(pos3d);
    const existing = cubes.find(c =>
      c.mesh.position.distanceTo(snapped) < 0.5
    );
    if (!existing) {
      createCube(snapped, selectedColor);
      showHud('✦ CUBO CREADO');
    }
    gestureEl.textContent = 'PINCH';
    setGestureCard('gc-pinch');
  }
  prevPinch = gesture.isPinch;

  // ── OPEN HAND → Rotate scene
  if (gesture.isOpen && !gesture.isPinch) {
    ghostCube.visible = false;
    if (prevHandPos) {
      const dx = wx - prevHandPos.x;
      const dy = wy - prevHandPos.y;
      sceneRotY += dx * 3;
      sceneRotX += dy * 1.5;
      sceneGroup.rotation.y = (sceneRotY * Math.PI) / 180;
      sceneGroup.rotation.x = Math.max(-30, Math.min(30,
